button_card_templates:
  choreops_chore_row_left:
    layout: icon_name_state2nd
    show_state: true
    show_name: true
    show_icon: true
    tap_action:
      action: call-service
      service: button.press
      service_data:
        entity_id: |
          [[[
            return entity.entity_id
              .replace('sensor.', 'button.')
              .replace('_choreops_chore_status_', '_choreops_claim_chore_');
          ]]]
      confirmation:
        text: |
          [[[
            const choreName = entity.attributes.chore_name
                           || entity.attributes.friendly_name
                           || entity.entity_id;
            const assignee = entity.attributes.assignee
                          || entity.attributes.user_name
                          || '';
            return assignee
              ? `Mark "${choreName}" as done for ${assignee}?`
              : `Mark "${choreName}" as done?`;
          ]]]
    hold_action:
      action: more-info
    name: |
      [[[
        const choreName = entity.attributes.chore_name
                       || entity.attributes.friendly_name
                       || entity.entity_id;
        const assignee = entity.attributes.assignee
                      || entity.attributes.user_name
                      || '';
        return assignee ? `${choreName}  ·  ${assignee}` : choreName;
      ]]]
    state:
      - value: due
        color: var(--error-color)
        icon: mdi:clock-alert-outline
        label: Due today
      - value: pending
        color: var(--warning-color)
        icon: mdi:clock-outline
        label: Pending
      - value: in_progress
        color: var(--info-color)
        icon: mdi:progress-check
        label: In progress
    styles:
      card:
        - padding: 4px 8px
        - border-radius: 8px
        - margin: 2px 4px
      grid:
        - grid-template-columns: min-content 1fr
        - justify-items: start
        - align-items: center
      name:
        - font-size: 0.9em
        - font-weight: 500
        - text-align: left
        - white-space: nowrap
        - overflow: hidden
        - text-overflow: ellipsis
      state:
        - font-size: 0.72em
        - text-align: left
        - color: var(--secondary-text-color)
      icon:
        - width: 28px
        - margin-right: 8px
